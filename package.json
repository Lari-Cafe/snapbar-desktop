{
  "name": "snapbar",
  "version": "0.1.2",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "preview": "vite preview",
    "site:build": "node scripts/build-site.mjs",
    "assets:prepare": "powershell -ExecutionPolicy Bypass -File scripts/prepare-runtime-assets.ps1",
    "assets:verify": "powershell -ExecutionPolicy Bypass -File scripts/verify-runtime-assets.ps1",

    "assets:verify-package": "powershell -ExecutionPolicy Bypass -File scripts/verify-runtime-assets.ps1 -PackageRoot src-tauri/target/release",
    "package": "npm run tauri build && npm run assets:verify-package",
    "tauri": "tauri"
  },
  "dependencies": {
    "@floating-ui/core": "^1.7.5",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-store": "^2.4.3",
    "lucide-react": "^1.16.0",
    "motion": "^12.42.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.7"
  }
}
